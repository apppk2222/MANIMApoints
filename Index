/* FIX MOBILE INPUT */
document.addEventListener('DOMContentLoaded', () => {
    const regNameInput = document.getElementById('reg-name');

    if (regNameInput) {
        // Force style
        regNameInput.style.pointerEvents = 'auto';
        regNameInput.style.touchAction = 'auto';
        regNameInput.style.userSelect = 'text';
        regNameInput.style.webkitUserSelect = 'text';
        regNameInput.style.zIndex = '9999';

        // Touch & Click
        const forceFocus = () => {
            regNameInput.focus();
            setTimeout(() => regNameInput.focus(), 30);
        };

        regNameInput.addEventListener('touchstart', forceFocus, { passive: false });
        regNameInput.addEventListener('click', forceFocus);
        regNameInput.addEventListener('focusin', forceFocus);

        // Double tap fix
        let lastTouch = 0;
        regNameInput.addEventListener('touchend', (e) => {
            const now = Date.now();
            if (now - lastTouch < 300) {
                forceFocus();
            }
            lastTouch = now;
        });
    }
});

