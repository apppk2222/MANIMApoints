async function toggleGuessStatus() {

  const btn =
    document.getElementById('guess-toggle-btn');

  const r = await api('getGuessStatus');

  let next =
    r.enabled === 'ON'
    ? 'OFF'
    : 'ON';

  const x = await api(
    'toggleGuessGame',
    { status: next }
  );

  if (!x.ok) {

    return showToast(x.error);
  }

  btn.textContent =
    next === 'ON'
    ? '🟢 เปิดกิจกรรม'
    : '🔴 ปิดกิจกรรม';

  btn.style.background =
    next === 'ON'
    ? '#27ae60'
    : '#c0392b';

  showToast(
    next === 'ON'
    ? 'เปิดกิจกรรมแล้ว'
    : 'ปิดกิจกรรมแล้ว'
  );
}

