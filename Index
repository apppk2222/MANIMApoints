<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0"><title>☕ MANIMA Points</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap');

:root {
  --bg:#1a0f00; --card:#261608; --card2:#321c0a;
  --gold:#d4a843; --gold2:#f0c96b; --cream:#f5e6c8;
  --text:#f0ddb8; --muted:#9a7c52; --red:#c0392b;
  --green:#27ae60; --accent:#e8821a;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Kanit',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* SCREENS */
.screen{display:none;min-height:100vh;flex-direction:column;}
.screen.active{
  display:flex;
  flex-direction:column;
}

/* TOPBAR */
.topbar{background:var(--card);padding:14px 18px;display:flex;align-items:center;
  justify-content:space-between;border-bottom:1px solid #3a2010;position:sticky;top:0;z-index:100;}
.topbar h2{font-size:1rem;font-weight:600;color:var(--gold);}
.back-btn{background:none;border:none;color:var(--gold);font-size:1.4rem;cursor:pointer;padding:4px 8px;line-height:1;}

/* LOGIN */
#screen-login{background:radial-gradient(ellipse at 30% 20%,#3d1e05 0%,#1a0f00 60%);
  align-items:center;justify-content:center;padding:30px 20px;}
.logo-wrap{text-align:center;margin-bottom:32px;}
.logo-icon{font-size:4rem;margin-bottom:6px;}
.logo-title{font-family:'Playfair Display',serif;font-size:2rem;color:var(--gold2);
  text-shadow:0 0 30px rgba(212,168,67,.5);}
.logo-sub{font-size:.8rem;color:var(--muted);letter-spacing:.15em;}

.form-card{background:var(--card);border-radius:20px;border:1px solid #3a2010;
  padding:26px 20px;width:100%;max-width:380px;box-shadow:0 8px 40px rgba(0,0,0,.5);}
.tab-row{display:flex;background:var(--bg);border-radius:12px;padding:4px;margin-bottom:20px;gap:4px;}
.tab-btn{flex:1;padding:10px;border:none;border-radius:9px;font-family:'Kanit',sans-serif;
  font-size:.9rem;font-weight:500;cursor:pointer;transition:all .25s;background:transparent;color:var(--muted);}
.tab-btn.active{background:var(--gold);color:#1a0f00;font-weight:700;box-shadow:0 2px 12px rgba(212,168,67,.3);}

.form-group{margin-bottom:14px;}
.form-group label{font-size:.78rem;color:var(--muted);margin-bottom:5px;display:block;}
.form-group input{width:100%;padding:12px 15px;background:var(--bg);border:1px solid #3a2010;
  border-radius:12px;color:var(--text);font-family:'Kanit',sans-serif;font-size:1rem;transition:border-color .2s;-webkit-appearance:none;}
.form-group input:focus{outline:none;border-color:var(--gold);}

.btn-primary{width:100%;padding:14px;background:linear-gradient(135deg,var(--gold) 0%,var(--accent) 100%);
  border:none;border-radius:14px;font-family:'Kanit',sans-serif;font-size:1rem;font-weight:700;
  color:#1a0f00;cursor:pointer;box-shadow:0 4px 20px rgba(212,168,67,.25);transition:all .2s;margin-top:4px;}
.btn-primary:active{transform:scale(.97);}
.btn-primary:disabled{opacity:.5;pointer-events:none;}

.admin-link{text-align:center;margin-top:18px;font-size:.8rem;color:var(--muted);}
.admin-link a{color:var(--gold);cursor:pointer;}

.tab-panel{display:none;}
.tab-panel.active{display:block;}

/* CUSTOMER HOME */
#screen-customer{background:var(--bg);}
.customer-body{flex:1;padding:18px 14px;overflow-y:auto;}
.points-hero{background:linear-gradient(135deg,#3d1e05 0%,#1a0800 100%);border:1px solid #3a2010;
  border-radius:22px;padding:26px 20px 20px;text-align:center;margin-bottom:18px;position:relative;overflow:hidden;}
.points-hero::before{content:'☕';position:absolute;top:-20px;right:-10px;font-size:8rem;opacity:.06;}
.ph-name{font-size:.85rem;color:var(--muted);margin-bottom:2px;}
.ph-phone{font-size:.78rem;color:var(--muted);margin-bottom:14px;}
.ph-points-label{font-size:.75rem;color:var(--muted);letter-spacing:.1em;}
.ph-points-num{font-family:'Playfair Display',serif;font-size:4rem;color:var(--gold2);
  text-shadow:0 0 30px rgba(212,168,67,.4);line-height:1;}
.ph-points-unit{font-size:.85rem;color:var(--gold);margin-top:2px;}

.action-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:18px;}
.action-card{background:var(--card);border:1px solid #3a2010;border-radius:16px;
  padding:18px 12px;text-align:center;cursor:pointer;transition:all .2s;}
.action-card:active{transform:scale(.96);background:var(--card2);}
.ac-icon{font-size:2rem;margin-bottom:7px;}
.ac-label{font-size:.85rem;font-weight:500;color:var(--cream);}
.ac-sub{font-size:.7rem;color:var(--muted);margin-top:2px;}

.section-title{font-size:.82rem;color:var(--muted);letter-spacing:.08em;margin-bottom:10px;font-weight:600;}
.history-list{display:flex;flex-direction:column;gap:8px;}
.history-item{background:var(--card);border-radius:12px;padding:12px 14px;
  display:flex;align-items:center;justify-content:space-between;border:1px solid #3a2010;}
.hi-left{display:flex;align-items:center;gap:10px;}
.hi-icon{font-size:1.3rem;}
.hi-title{font-size:.85rem;font-weight:500;}
.hi-date{font-size:.7rem;color:var(--muted);}
.hi-pts{font-weight:700;font-size:1rem;}
.hi-pts.plus{color:var(--green);}
.hi-pts.minus{color:var(--red);}

.bottom-nav{background:var(--card);border-top:1px solid #3a2010;display:flex;padding:10px 0 20px;}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px;
  border:none;background:none;cursor:pointer;color:var(--muted);font-family:'Kanit',sans-serif;
  font-size:.68rem;transition:color .2s;}
.nav-btn.active{color:var(--gold);}
.nav-icon{font-size:1.4rem;}

/* MY QR */
#screen-myqr{background:var(--bg);}
.qr-body{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px 20px;}
.qr-card{background:#fff;border-radius:22px;padding:22px;width:230px;text-align:center;
  box-shadow:0 8px 40px rgba(0,0,0,.5);}
#qr-canvas{display:flex;justify-content:center;}
.qr-phone-label{margin-top:12px;font-size:.9rem;font-weight:700;color:#1a0f00;font-family:'Kanit',sans-serif;}
.qr-hint{font-size:.78rem;color:var(--muted);margin-top:16px;text-align:center;line-height:1.6;}

/* REDEEM */
#screen-redeem{background:var(--bg);}
.redeem-body{flex:1;padding:18px 14px;overflow-y:auto;}
.pts-display{background:var(--card);border-radius:14px;border:1px solid #3a2010;
  padding:14px;text-align:center;margin-bottom:18px;}
.pd-label{font-size:.78rem;color:var(--muted);}
.pd-num{font-family:'Playfair Display',serif;font-size:2.5rem;color:var(--gold2);}

.redeem-title{font-size:.82rem;color:var(--muted);margin-bottom:10px;font-weight:600;}
.pts-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:22px;}
.pts-chip{background:var(--card);border:1.5px solid #3a2010;border-radius:10px;padding:10px 4px;
  text-align:center;font-size:.85rem;font-weight:600;cursor:pointer;transition:all .2s;color:var(--cream);}
.pts-chip.selected{border-color:var(--gold);background:rgba(212,168,67,.15);color:var(--gold2);}
.pts-chip.disabled{opacity:.3;pointer-events:none;}

.redeem-qr-wrap{background:var(--card);border-radius:18px;border:1px solid #3a2010;padding:20px;
  flex-direction:column;align-items:center;display:none;}
.redeem-qr-wrap.show{display:flex;}
#redeem-qr-canvas{background:#fff;border-radius:12px;padding:10px;}
.rqr-label{margin-top:12px;font-size:.9rem;color:var(--muted);text-align:center;}
.rqr-pts{font-size:1.3rem;font-weight:700;color:var(--red);text-align:center;}

/* ADMIN */
#screen-admin{background:var(--bg);}
.admin-body{flex:1;padding:18px 14px;overflow-y:auto;}
.admin-info{background:var(--card);border-radius:14px;border:1px solid #3a2010;
  padding:14px 16px;margin-bottom:18px;display:flex;align-items:center;gap:12px;}
.ai-role{font-size:.72rem;color:var(--gold);font-weight:600;}
.ai-name{font-size:.95rem;font-weight:600;}
.admin-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px;}
.stat-card{background:var(--card);border:1px solid #3a2010;border-radius:14px;padding:14px;text-align:center;}
.stat-num{font-family:'Playfair Display',serif;font-size:2rem;color:var(--gold2);}
.stat-label{font-size:.72rem;color:var(--muted);}

.admin-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px;}
.admin-card{background:var(--card);border:1px solid #3a2010;border-radius:18px;
  padding:18px 12px;text-align:center;cursor:pointer;transition:all .2s;}
.admin-card:active{transform:scale(.96);}
.adc-icon{font-size:2.2rem;margin-bottom:8px;}
.adc-label{font-size:.88rem;font-weight:600;color:var(--cream);}
.adc-sub{font-size:.68rem;color:var(--muted);margin-top:3px;}
.admin-card.give{border-color:rgba(39,174,96,.4);}
.admin-card.deduct{border-color:rgba(192,57,43,.4);}

.customer-list{display:flex;flex-direction:column;gap:8px;}
.cl-item{background:var(--card);border-radius:12px;border:1px solid #3a2010;
  padding:12px 14px;display:flex;align-items:center;justify-content:space-between;}
.cl-name{font-size:.9rem;font-weight:600;}
.cl-phone{font-size:.72rem;color:var(--muted);}
.cl-pts{font-weight:700;color:var(--gold);}
.cl-rank{font-size:.75rem;color:var(--muted);background:var(--bg);border-radius:6px;padding:2px 7px;}

/* SCANNER */
#screen-scanner{background:#000;}
.scanner-body{flex:1;position:relative;display:flex;flex-direction:column;align-items:center;overflow:hidden;}
#scanner-video{width:100%;height:100%;object-fit:cover;min-height:calc(100vh - 55px);}
.scan-overlay{position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;pointer-events:none;}
.scan-frame{width:220px;height:220px;border:2px solid var(--gold);border-radius:18px;
  box-shadow:0 0 0 9999px rgba(0,0,0,.55);position:relative;}
.scan-frame::before,.scan-frame::after{content:'';position:absolute;width:30px;height:30px;
  border-color:var(--gold2);border-style:solid;}
.scan-frame::before{top:-2px;left:-2px;border-width:3px 0 0 3px;border-radius:4px 0 0 0;}
.scan-frame::after{bottom:-2px;right:-2px;border-width:0 3px 3px 0;border-radius:0 0 4px 0;}
.scan-line{position:absolute;left:4px;right:4px;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold2),transparent);animation:scan 2s infinite;}
@keyframes scan{0%{top:10px;}100%{top:200px;}}
.scan-hint{margin-top:18px;color:var(--cream);font-size:.85rem;text-align:center;padding:0 20px;}
.scan-mode-badge{position:absolute;top:70px;left:50%;transform:translateX(-50%);
  background:rgba(0,0,0,.75);border:1px solid var(--gold);border-radius:20px;
  padding:6px 18px;font-size:.8rem;color:var(--gold);font-weight:600;white-space:nowrap;}

/* MODALS */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.82);z-index:200;
  align-items:flex-end;justify-content:center;}
.modal-overlay.show{display:flex;}
.modal-sheet{background:var(--card);border-radius:24px 24px 0 0;border:1px solid #3a2010;
  border-bottom:none;padding:26px 22px 36px;width:100%;max-width:480px;animation:slideUp .3s ease;}
@keyframes slideUp{from{transform:translateY(100%);}to{transform:translateY(0);}}
.modal-icon{text-align:center;font-size:3rem;margin-bottom:10px;}
.modal-title{text-align:center;font-size:1.15rem;font-weight:700;margin-bottom:6px;}
.modal-body{text-align:center;color:var(--muted);font-size:.88rem;margin-bottom:20px;line-height:1.7;}
.highlight{color:var(--gold2);font-size:1.4rem;font-weight:700;}
.modal-btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--gold),var(--accent));
  border:none;border-radius:14px;font-family:'Kanit',sans-serif;font-size:1rem;font-weight:700;
  color:#1a0f00;cursor:pointer;}
.modal-btn:disabled{opacity:.5;pointer-events:none;}
.modal-btn-sec{width:100%;padding:12px;background:transparent;border:1px solid #3a2010;
  border-radius:12px;color:var(--muted);font-family:'Kanit',sans-serif;font-size:.9rem;cursor:pointer;margin-top:10px;}
.modal-input{width:100%;padding:13px 15px;background:var(--bg);border:1px solid #3a2010;
  border-radius:12px;color:var(--text);font-family:'Kanit',sans-serif;font-size:1rem;margin-bottom:14px;}
.modal-input:focus{outline:none;border-color:var(--gold);}
.modal-pts-info{background:var(--bg);border-radius:12px;padding:12px;margin-bottom:14px;text-align:center;}
.mpi-label{font-size:.78rem;color:var(--muted);}
.mpi-num{font-size:1.6rem;font-weight:700;color:var(--gold2);}

/* TOAST */
.toast{position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:var(--card2);
  border:1px solid var(--gold);color:var(--cream);padding:11px 20px;border-radius:50px;
  font-size:.83rem;z-index:999;opacity:0;transition:opacity .3s;white-space:nowrap;pointer-events:none;}
.toast.show{opacity:1;}

/* LOADING */
.loading-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:300;
  align-items:center;justify-content:center;flex-direction:column;gap:14px;}
.loading-overlay.show{display:flex;}
.spinner{width:44px;height:44px;border:3px solid #3a2010;border-top-color:var(--gold);
  border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.loading-text{color:var(--muted);font-size:.88rem;}

/* FIX INPUT AND TOUCH */
#screen-login input,
#reg-name {
    pointer-events: auto !important;
    touch-action: auto !important;
    user-select: text !important;
    -webkit-user-select: text !important;
    -webkit-touch-callout: text !important;
    position: relative !important;
    z-index: 9999 !important;
    font-size: 16px !important;           /* สำคัญมาก */
    background: var(--bg) !important;
    color: var(--text) !important;
    -webkit-appearance: none;
    appearance: none;
}

/* เฉพาะช่องชื่อ */
#reg-name {
    font-size: 16px !important;
    padding: 13px 15px !important;
    min-height: 52px !important;
}

/* TOGGLE SWITCH */
.switch{
  position:relative;
  display:inline-block;
  width:58px;
  height:32px;
}

.switch input{
  display:none;
}

.slider{
  position:absolute;
  cursor:pointer;
  inset:0;
  background:#555;
  transition:.25s;
  border-radius:50px;
}

.slider:before{
  content:"";
  position:absolute;
  width:24px;
  height:24px;
  left:4px;
  top:4px;
  background:white;
  transition:.25s;
  border-radius:50%;
}

.switch input:checked + .slider{
  background:var(--green);
}

.switch input:checked + .slider:before{
  transform:translateX(26px);
}
</style>
</head>
<body>

<!-- LOADING -->
<div class="loading-overlay" id="loading">
  <div class="spinner"></div>
  <div class="loading-text" id="loading-text">กำลังโหลด...</div>
</div>

<!-- ══ LOGIN ══ -->
<div id="screen-login" class="screen active">
  <div class="logo-wrap">
    <div class="logo-icon">☕</div>
    <div class="logo-title">MANIMA Points</div>
    <div class="logo-sub">bakery&restaurant</div>
  </div>
  <div class="form-card">
    <div class="tab-row">
      <button class="tab-btn active" onclick="switchTab('login')">เข้าสู่ระบบ</button>
      <button class="tab-btn" onclick="switchTab('register')">ลงทะเบียน</button>
    </div>
    <div id="tab-login" class="tab-panel active">
      <div class="form-group"><label>เบอร์โทรศัพท์</label>
        <input type="tel" id="login-phone" placeholder="**********" maxlength="10">
      </div>
      <button class="btn-primary" onclick="doLogin()">เข้าสู่ระบบ</button>
    </div>
    <div id="tab-register" class="tab-panel">
  <div class="form-group">
    <label>เบอร์โทรศัพท์</label>
    <input type="tel" id="reg-phone" placeholder="โปรดกรอกเบอร์โทรศัพท์ของท่าน" maxlength="10">
  </div>
  <div class="form-group">
    <label>ชื่อผู้ใช้</label>
    <input type="text" id="reg-name" placeholder="ชื่อผู้ใช้" 
           autocomplete="name" 
           autocorrect="off" 
           spellcheck="false"
           inputmode="text">
  </div>
      <button class="btn-primary" onclick="doRegister()">ลงทะเบียน</button>
    </div>
    <div class="admin-link"><a onclick="goScreen('admin-login')">🔐 เข้าสู่ระบบแอดมิน</a></div>
  </div>
</div>

<!-- ══ CUSTOMER HOME ══ -->
<div id="screen-customer" class="screen">
  <div class="customer-body">
    <div class="points-hero">
      <div class="ph-name" id="cust-name-display"></div>
      <div class="ph-phone" id="cust-phone-display"></div>
      <div class="ph-points-label">POINTS</div>
      <div class="ph-points-num" id="cust-pts-display">0</div>
      <div class="ph-points-unit">แต้มสะสม</div>
    </div>
  <div class="action-grid">
  <!-- เพิ่มปุ่มหน้าแรกตรงนี้ -->
  <div class="action-card" onclick="refreshCustomer()">
    <div class="ac-icon">🏠</div>
    <div class="ac-label">หน้าแรก</div>
    <div class="ac-sub">รีเฟรช(Refresh)</div>
  </div>

  <div class="action-card" onclick="showMyQR()">
    <div class="ac-icon">📱</div>
    <div class="ac-label">QR ของฉัน</div>
    <div class="ac-sub">รับแต้มจากแคชเชียร์</div>
  </div>
  
  <div class="action-card" onclick="showRedeem()">
    <div class="ac-icon">🎁</div>
    <div class="ac-label">แลกของรางวัล</div>
    <div class="ac-sub">ใช้แต้มสะสม</div>
  </div>
  
  <div class="action-card" onclick="showGuessGame()">
    <div class="ac-icon">🎯</div>
    <div class="ac-label">ทายเลข</div>
    <div class="ac-sub">ใช้แต้มลุ้นรางวัล</div>
  </div>
</div>
    <div class="section-title">ประวัติล่าสุด</div>
    <div class="history-list" id="history-list">
      <div style="text-align:center;color:var(--muted);font-size:.85rem;padding:20px">กำลังโหลด...</div>
    </div>
  </div>
  <div class="bottom-nav">
    <button class="nav-btn active" onclick="refreshCustomer()"><span class="nav-icon">🏠</span>หน้าแรก</button>
    <button class="nav-btn" onclick="showMyQR()"><span class="nav-icon">📱</span>QR ของฉัน</button>
    <button class="nav-btn" onclick="showRedeem()"><span class="nav-icon">🎁</span>แลกรางวัล</button>
    <button class="nav-btn" onclick="doLogout()"><span class="nav-icon">🚪</span>ออกจากระบบ</button>
  </div>
</div>

<!-- ══ MY QR ══ -->
<div id="screen-myqr" class="screen">
  <div class="topbar">
    <button class="back-btn" onclick="goScreen('customer')">←</button>
    <h2>QR Code ของฉัน</h2><div></div>
  </div>
  <div class="qr-body">
    <div class="qr-card">
      <div id="qr-canvas"></div>
      <div class="qr-phone-label" id="qr-phone-label"></div>
    </div>
    <div class="qr-hint">แสดง QR นี้ให้แคชเชียร์สแกน<br>เพื่อรับแต้มสะสม ☕<br><br>
      <span style="color:var(--gold);font-size:.72rem">แต้มปัจจุบัน: <b id="qr-pts-hint">0</b> แต้ม</span>
    </div>
  </div>
</div>

<!-- ══ REDEEM ══ -->
<div id="screen-redeem" class="screen">
  <div class="topbar">
    <button class="back-btn" onclick="goScreen('customer')">←</button>
    <h2>แลกของรางวัล</h2><div></div>
  </div>
  <div class="redeem-body">
    <div class="pts-display">
      <div class="pd-label">แต้มของคุณ</div>
      <div class="pd-num" id="redeem-pts-display">0</div>
    </div>
    <div class="redeem-title">เลือกจำนวนแต้มที่ต้องการใช้</div>
    <div class="pts-grid" id="pts-grid"></div>
    <div class="redeem-qr-wrap" id="redeem-qr-wrap">
