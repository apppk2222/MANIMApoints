<script>
// ══════════════════════════════
// CONFIG
// ══════════════════════════════
// URL ของ Google Apps Script Web App ที่ Deploy แล้ว
// เปลี่ยนเป็น URL จริงของคุณ
const API_URL = 'https://script.google.com/macros/s/AKfycbw_OPu4IRkcd_UKZRkQsFZkM6ejd83NctwFUu7bv-qZmSEX5KMuIO3pjIdP_WWUnSc/exec';

let currentUser = null;
// ══════════════════════════════
// SESSION
// ══════════════════════════════
function saveSession() {
  localStorage.setItem('coffee_points_user', JSON.stringify(currentUser));
}

async function loadSession() {

  const data = localStorage.getItem('coffee_points_user');

  if (!data) return false;

  try {

    currentUser = JSON.parse(data);

    // ═════════ ADMIN ═════════
    if (currentUser.isAdmin) {

      await refreshAdmin();

      goScreen('admin');

      return true;
    }

    // ═════════ CUSTOMER ═════════
    const r = await api('getCustomer', {
      phone: currentUser.phone
    });

    // ถ้าหาลูกค้าไม่เจอ → logout
    if (!r.ok) {

      clearSession();

      currentUser = null;

      goScreen('login');

      return false;
    }

    // อัพเดทข้อมูลล่าสุด
    currentUser = r.customer;

    // บันทึก session ใหม่
    saveSession();

    // โหลดหน้าใหม่
   await renderCustomerHome(false);

// โหลดประวัติทีหลัง เพื่อให้หน้าแสดงเร็ว
setTimeout(() => {
  loadHistory();
}, 50);

goScreen('customer');

return true;

  } catch (e) {

    console.error(e);

    clearSession();

    currentUser = null;

    return false;
  }
}

function clearSession() {
  localStorage.removeItem('coffee_points_user');
}
let scanMode = 'give';
let scanStream = null;
let scanRaf = null;
let pendingScan = null;

// ══════════════════════════════
// API CALL
// ══════════════════════════════
async function api(action, data = {}) {

  let loadingTimer;

  try {

    // รอ 250ms ก่อนค่อยโชว์ loading
    loadingTimer = setTimeout(() => {
      showLoading('กำลังประมวลผล...');
    }, 250);

    const res = await fetch(API_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'text/plain;charset=utf-8'
      },
      body: JSON.stringify({
        action,
        ...data
      })
    });

    clearTimeout(loadingTimer);

    hideLoading();

    return await res.json();

  } catch (e) {

    clearTimeout(loadingTimer);

    hideLoading();

    return {
      ok:false,
      error:'ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้'
    };
  }
}

// ══════════════════════════════
// SCREENS
// ══════════════════════════════
function goScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
  window.scrollTo(0, 0);
}
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    b.classList.toggle('active', (i===0&&tab==='login')||(i===1&&tab==='register'));
  });
  document.getElementById('tab-login').classList.toggle('active', tab==='login');
  document.getElementById('tab-register').classList.toggle('active', tab==='register');
}

// ══════════════════════════════
// AUTH
// ══════════════════════════════
async function doLogin() {
  const phone = document.getElementById('login-phone').value.trim();
  if (!phone || phone.length < 9) return showToast('กรุณากรอกเบอร์โทรให้ถูกต้อง');
  const r = await api('login', { phone });
  if (!r.ok) return showToast(r.error);
  currentUser = r.customer;
saveSession();

renderCustomerHome();
goScreen('customer');
}

async function doRegister() {
  const name  = document.getElementById('reg-name').value.trim();
  const phone = document.getElementById('reg-phone').value.trim();
  if (!name) return showToast('กรุณากรอกชื่อ');
  if (!phone || phone.length < 9) return showToast('กรุณากรอกเบอร์โทรให้ถูกต้อง');
  const r = await api('register', { name, phone });
  if (!r.ok) return showToast(r.error);
  currentUser = r.customer;
saveSession();

showToast('ลงทะเบียนสำเร็จ! ยินดีต้อนรับ ☕');
  setTimeout(() => { renderCustomerHome(); goScreen('customer'); }, 600);
}

async function doAdminLogin() {
  const password = document.getElementById('admin-pass').value;
  if (!password) return showToast('กรุณากรอกรหัสผ่าน');
  const r = await api('adminLogin', { password });
  if (!r.ok) return showToast(r.error || 'รหัสผ่านไม่ถูกต้อง');
  document.getElementById('admin-pass').value = '';
  currentUser = { isAdmin: true };
saveSession();

refreshAdmin();
goScreen('admin');
}

function doLogout() {

  // ปิดกล้องถ้ายังเปิดอยู่
  if (scanRaf) {
    cancelAnimationFrame(scanRaf);
    scanRaf = null;
  }

  if (scanStream) {
    scanStream.getTracks().forEach(t => t.stop());
    scanStream = null;
  }

  currentUser = null;

  clearSession();

  goScreen('login');
}

// ══════════════════════════════
// CUSTOMER
// ══════════════════════════════
async function renderCustomerHome(loadHist = true) {

  document.getElementById('cust-name-display').textContent =
    currentUser.name;

  document.getElementById('cust-phone-display').textContent =
    currentUser.phone;

  document.getElementById('cust-pts-display').textContent =
    currentUser.points;

  // โหลด history เฉพาะจำเป็น
  if (loadHist) {
    loadHistory();
  }
}

async function refreshCustomer() {
  // 1. ดึงข้อมูลล่าสุดจาก Server ก่อน (แต้มและข้อมูลผู้ใช้)
  const r = await api('getCustomer', { phone: currentUser.phone });
  
  if (r.ok) {
    // 2. อัปเดตข้อมูลแต้มในตัวแปรหลัก
    currentUser.points = r.customer.points;
    
    // 3. สั่งวาดหน้าจอใหม่ทันที
    // ให้มั่นใจว่าฟังก์ชันนี้อัปเดตค่าแต้มใน HTML ของคุณแล้ว
    renderCustomerHome(); 
    
    // 4. สั่งโหลดประวัติทันทีโดยไม่ต้องรอผู้ใช้กดซ้ำ
    await loadHistory();
    
    console.log("รีเฟรชข้อมูลครบถ้วนแล้ว: แต้มใหม่คือ", r.customer.points);
  } else {
    console.error("รีเฟรชไม่สำเร็จ:", r.error);
  }
}

async function loadHistory() {
  const el = document.getElementById('history-list');
  const showMessage = (msg) => {
    el.innerHTML = `<div style="text-align:center;color:var(--muted);font-size:.85rem;padding:20px">${msg}</div>`;
  };

  showMessage('กำลังโหลด...');

  const r = await api('getHistory', { phone: currentUser.phone });

  if (!r.ok || !r.history || r.history.length === 0) {
    showMessage('ยังไม่มีประวัติ');
    return;
  }

 // ใช้ slice() เพื่อทำสำเนา แล้วค่อย reverse()
// เปลี่ยนช่วงการจัดการ history เป็นแบบนี้ครับ
let history = r.history.filter(h => {
    if (h.type === 'guess_reward') {
      return h.number !== undefined && h.number !== null && h.number !== '';
    }
    return true;
});

// บังคับเรียงใหม่ด้วย date (ใหม่ -> เก่า)
history.sort((a, b) => new Date(b.date) - new Date(a.date));

  // --- เพิ่มบรรทัดนี้เพื่อดูข้อมูลใน Console ---
  console.log("ข้อมูลประวัติที่ได้รับจาก API:", history);
  // ------------------------------------------

  el.innerHTML = history.map(h => {
    const isPlus = ['earn', 'guess_reward'].includes(h.type);
    const absPoints = Math.abs(Number(h.points || 0));
    
    // ตรงนี้คือส่วนที่แก้ไข: ตรวจสอบหลายชื่อ (h.number, h.guess, h.value) 
    // เพื่อดึงค่าจากคอลัมน์ D มาแสดงผล
    const luckyNum = h.number || h.guess || h.value || '-';

    // ในไฟล์หน้าเว็บ (JavaScript)
let title = 'รายการ';
if (h.type === 'guess_reward') {
    // ถ้าไม่มี number ให้แสดงแค่ "ถูกรางวัล"
    title = h.number ? `🎉 ถูกรางวัลเลข ${h.number}` : '🎉 ถูกรางวัล';
} 
else if (h.type === 'guess_play') {
    // อันนี้ยังแสดงเลขปกติ
    title = h.number ? `🎯 ทายเลข ${h.number}` : '🎯 ทายเลข';
}
else if (h.type === 'earn') {
    title = '☕ ได้รับแต้ม';
}
else {
    title = '🎁 ใช้แต้ม';
}

    return `
      <div class="history-item">
        <div class="hi-left">
          <div class="hi-icon">${isPlus ? '☕' : '🎁'}</div>
          <div>
            <div class="hi-title">${title}</div>
            <div class="hi-date">${h.date ? h.date.split('T')[0] : '-'}</div>
          </div>
        </div>
        <div class="hi-pts ${isPlus ? 'plus' : 'minus'}">
          ${isPlus ? '+' : '-'}${absPoints}
        </div>
      </div>
    `;
  }).join('');
}
