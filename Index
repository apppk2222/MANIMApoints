// ══════════════════════════════
// SCANNER
// ══════════════════════════════
// ══════════════════════════════
// SCANNER
// ══════════════════════════════
function openScanner(mode) {
  scanMode = mode;
  document.getElementById('scanner-title').textContent = mode === 'give' ? 'สแกนให้แต้ม' : 'สแกนแลกรางวัล';
  document.getElementById('scan-mode-badge').textContent = mode === 'give' ? '🟢 จ่ายแต้ม' : '🔴 หักแต้ม';
  goScreen('scanner');
  startCamera();
}

async function startCamera() {
  try {
    scanStream = await navigator.mediaDevices.getUserMedia({
      video: {
        facingMode: { ideal: 'environment' },
        width: { ideal: 1280 },
        height: { ideal: 720 }
      }
    });
    const v = document.getElementById('scanner-video');
    v.srcObject = scanStream;
    await v.play();
    tickScan();
  } catch (e) {
    console.error('Camera error:', e);
    showToast('ไม่สามารถเปิดกล้องได้: ' + e.message);
    goScreen('admin');
  }
}

function tickScan() {
  // หยุดถ้าออกจากหน้า scanner แล้ว
  if (!document.getElementById('screen-scanner').classList.contains('active')) return;

  const v = document.getElementById('scanner-video');
  const c = document.getElementById('scanner-canvas');

  if (typeof jsQR === 'undefined') {
    console.error('jsQR ยังโหลดไม่เสร็จ');
    scanRaf = requestAnimationFrame(tickScan);
    return;
  }

  if (v.readyState >= v.HAVE_ENOUGH_DATA && v.videoWidth > 0) {
    c.width = v.videoWidth;
    c.height = v.videoHeight;
    const ctx = c.getContext('2d');
    ctx.drawImage(v, 0, 0, c.width, c.height);
    const imageData = ctx.getImageData(0, 0, c.width, c.height);
    const code = jsQR(imageData.data, imageData.width, imageData.height, {
      inversionAttempts: 'dontInvert'
    });
    if (code && code.data) {
      handleQR(code.data);
      return; // หยุด loop — handleQR จะจัดการต่อ
    }
  }

  scanRaf = requestAnimationFrame(tickScan);
}

function stopScanner() {
  if (scanRaf) { cancelAnimationFrame(scanRaf); scanRaf = null; }
  if (scanStream) { scanStream.getTracks().forEach(t => t.stop()); scanStream = null; }
  goScreen('admin');
}

async function handleQR(data) {

  if (scanRaf) {
    cancelAnimationFrame(scanRaf);
    scanRaf = null;
  }

  if (scanStream) {
    scanStream.getTracks().forEach(t => t.stop());
    scanStream = null;
  }

  console.log("QR DATA:", data);

  const parts = data.split(':');

  if (parts[0] !== 'CPLOYALTY') {

    showToast('QR ไม่ถูกต้อง');

    setTimeout(() => {
      goScreen('admin');
    }, 800);

    return;
  }

  const type  = parts[1];
  const phone = parts[2];
  const pts   = parseInt(parts[3]) || 0;

  const r = await api('getCustomer', { phone });

  if (!r.ok) {

    showToast(r.error || 'ไม่พบลูกค้า');

    setTimeout(() => {
      goScreen('admin');
    }, 800);

    return;
  }

  const cust = r.customer;

  // =========================
  // GIVE POINTS
  // =========================
  if (type === 'EARN' && scanMode === 'give') {

    pendingScan = {
      phone,
      type:'earn'
    };

    document.getElementById('modal-give-current').textContent =
      cust.points + ' แต้ม';

    document.getElementById('modal-give-info').innerHTML =
      `<b style="color:var(--cream)">
        ${cust.name}
      </b><br>${phone}`;

    document.getElementById('give-pts-input').value = '';

    goScreen('admin');

    setTimeout(() => {
      document.getElementById('modal-give')
        .classList.add('show');
    }, 200);

  }

  // =========================
  // REDEEM
  // =========================
  else if (type === 'REDEEM' && scanMode === 'deduct') {

    pendingScan = {
      phone,
      pts,
      type:'redeem'
    };

    const after = cust.points - pts;

    document.getElementById('modal-deduct-info').innerHTML = `
      <b style="color:var(--cream)">
        ${cust.name}
      </b>
      (${phone})
      <br><br>

      แต้มปัจจุบัน:
      <span style="color:var(--gold2);font-weight:700">
        ${cust.points}
      </span>

      <br>

      หักแต้ม:
      <span style="color:var(--red);font-weight:700">
        -${pts}
      </span>

      <br>

      คงเหลือ:
      <span style="
        color:${after < 0 ? 'red':'#27ae60'};
        font-weight:700
      ">
        ${after < 0 ? 'แต้มไม่พอ' : after}
      </span>
    `;

    goScreen('admin');

    setTimeout(() => {
      document.getElementById('modal-deduct')
        .classList.add('show');
    }, 200);

  }

  else {

    showToast('QR ไม่ตรงกับโหมด');

    setTimeout(() => {
      goScreen('admin');
    }, 1000);

  }

}

async function confirmGivePoints() {
  const pts = parseInt(document.getElementById('give-pts-input').value);
  if (!pts || pts < 1) return showToast('กรุณากรอกจำนวนแต้ม');
  const btn = document.getElementById('modal-give-btn');
  btn.disabled = true;
  const r = await api('givePoints', { phone: pendingScan.phone, points: pts });
  btn.disabled = false;
  if (!r.ok) { showToast(r.error); return; }
  closeModal('modal-give');
  document.getElementById('success-icon').textContent  = '✅';
  document.getElementById('success-title').textContent = 'ให้แต้มสำเร็จ!';
  document.getElementById('success-body').innerHTML =
    `<b style="color:var(--cream)">${r.name}</b><br>
     ได้รับ <span class="highlight">+${pts}</span> แต้ม<br>
     รวมทั้งหมด <b>${r.newPoints}</b> แต้ม`;
  document.getElementById('modal-success').classList.add('show');
}

async function confirmDeductPoints() {
  const btn = document.getElementById('modal-deduct-btn');
  btn.disabled = true;
  const r = await api('deductPoints', { phone: pendingScan.phone, points: pendingScan.pts });
  btn.disabled = false;
  if (!r.ok) { showToast(r.error); closeModal('modal-deduct'); return; }
  closeModal('modal-deduct');
  document.getElementById('success-icon').textContent  = '🎁';
  document.getElementById('success-title').textContent = 'แลกของรางวัลสำเร็จ!';
  document.getElementById('success-body').innerHTML =
    `<b style="color:var(--cream)">${r.name}</b><br>
     ใช้ <span class="highlight" style="color:var(--red)">-${pendingScan.pts}</span> แต้ม<br>
     คงเหลือ <b>${r.newPoints}</b> แต้ม`;
  document.getElementById('modal-success').classList.add('show');
}

