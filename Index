async function showGuessGame() {
  // 1. ดึงประวัติการทายเลขล่าสุดจาก Sheet มาแสดงก่อน
  // การทำแบบนี้จะทำให้ผู้ใช้เห็นข้อมูลที่เป็นปัจจุบันที่สุด
  await loadHistory();

  // 2. ตรวจสอบสถานะกิจกรรม
  const r = await api('getGuessStatus');
  console.log(r);

  if (!r.ok) {
    return showToast('โหลดสถานะกิจกรรมไม่ได้');
  }

  // 3. บังคับแปลงข้อความ
  const status = String(r.enabled).trim().toUpperCase();

  if (status !== 'ON') {
    return showToast('กิจกรรมยังไม่เปิด (' + status + ')');
  }

  // 4. เปิด Modal หลังจากโหลดประวัติและเช็คสถานะผ่านแล้ว
  document.getElementById('modal-guess').classList.add('show');
}

async function submitGuessUI() {
  const numberInput = document.getElementById('guess-number');
  const pointsInput = document.getElementById('guess-points');

  const number = numberInput.value;
  const points = pointsInput.value;

  // 1. เรียก API ทายผล
  const r = await api('submitGuess', {
    phone: currentUser.phone,
    number,
    points
  });

  if (!r.ok) {
    return showToast(r.error);
  }

  // 2. ถ้าทายสำเร็จ ให้เคลียร์ช่อง
  numberInput.value = '';
  pointsInput.value = '';

  // 3. ปิด Modal
  closeModal('modal-guess');

  // 4. สั่งอัปเดตหน้าจอทั้งหมด (เรียก refreshCustomer จากที่นี่)
  // เพราะเมื่อทายสำเร็จ เราต้องการให้แต้มอัปเดตและประวัติโหลดใหม่
  refreshCustomer(); 

  showToast('ทายเลขสำเร็จ 🎯');
}

