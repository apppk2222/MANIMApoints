async function refreshAdmin() {
  const r = await api('getAllCustomers');
  if (!r.ok) return;
  const customers = r.customers;
  const totalPts  = customers.reduce((s,c) => s + c.points, 0);
  document.getElementById('stat-total-cust').textContent = customers.length;
